# =============================================================================
# RowTech Dashboard Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# =============================================================================

# Supabase project URL — found in Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous public key — safe for client-side use
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — SECRET. Only used in API routes (server-side).
# Never expose this to the client. Never commit to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Hub authentication secret — must match HUB_SECRET compiled into hub firmware.
# Generate a strong random string: openssl rand -hex 32
HUB_SECRET=your-hub-secret-here

# Public app URL (used for auth email redirect links)
NEXT_PUBLIC_APP_URL=https://your-vercel-app.vercel.app
